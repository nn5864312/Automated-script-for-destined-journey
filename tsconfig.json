{
  "compilerOptions": {
    "types": ["jquery", "lodash", "toastr", "type-fest", "zod", "jest"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "@types/**/*", "*.d.ts"],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
